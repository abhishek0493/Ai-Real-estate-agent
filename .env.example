# ===========================================
# Application
# ===========================================
APP_NAME=AI Real Estate Sales Agent
ENVIRONMENT=development
DEBUG=true

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_DB=ai_real_estate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/ai_real_estate

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# Celery
# ===========================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===========================================
# Auth
# ===========================================
SECRET_KEY=changeme-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
SUPER_ADMIN_TENANT_GENERATE_KEY=your-super-secret-key

# ===========================================
# LLM / AI
# ===========================================
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-3.5-turbo

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
